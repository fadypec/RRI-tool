{
  "name": "rri-steer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
